      <text bytes="325" sha1="8csdit9694gc6nf52lzr68xtf7ihb8s" xml:space="preserve">/* {{pp-template|small=yes}} */
.ib-company .infobox-label {
	padding-right: 0.5em;
}

.ib-company .infobox-data,
.ib-company .infobox-below {
	line-height: 1.35em;
}

/* always light background for logos */
.ib-company-logo img {
	background-color: #f8f9fa;
}

.ib-company-locality,
.ib-company-country {
	display: inline;
}</text>
