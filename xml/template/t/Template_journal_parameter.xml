      <comment>Avoid calling subtemplates; fix the behavior in front for parameters with empty names</comment>
      <origin>779195</origin>
      <model>wikitext</model>
      <format>text/x-wiki</format>
      <text bytes="580" sha1="19xmiv0dxpr67yqtx6rp7rdm7phg9f2" xml:space="preserve">&lt;includeonly&gt;{{#if:{{{1|}}}
	|&lt;templatestyles src="Template:Template journal inline/styles.css" /&gt;&lt;span class="tj-tape"&gt;{{#invoke:MultiReplace|main
		| plain = no
		| 1 = {{{1|}}}
		| 2 = ^([^:].-)%s*:%s*(.*)$
		| 3 = &lt;span class{{=}}"tj-an"&gt;%1&lt;/span&gt;&lt;span class{{=}}"tj-nc"&gt;&amp;#61;&lt;/span&gt;&lt;span class{{=}}"tj-ac"&gt;%2&lt;/span&gt;
		| 4 = ^[^:]+$
		| 5 = &lt;span class{{=}}"tj-ac"&gt;%0&lt;/span&gt;
		| 6 = ^:%s*(.*)$
		| 7 = &lt;span class{{=}}"tj-nc"&gt;&amp;#61;&lt;/span&gt;&lt;span class{{=}}"tj-ac"&gt;%1&lt;/span&gt;
	}}&lt;/span&gt;
	|{{Error|Error: Missing parameter}}
}}&lt;/includeonly&gt;&lt;noinclude&gt;{{documentation}}&lt;/noinclude&gt;</text>
      <sha1>19xmiv0dxpr67yqtx6rp7rdm7phg9f2</sha1>
