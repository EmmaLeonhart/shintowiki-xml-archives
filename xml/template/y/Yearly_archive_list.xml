      <text bytes="395" sha1="ezfbrkfcv5jqbsiao3g3nslxxx8na5v" xml:space="preserve">{{#invoke:string|replace
|source  =
{{for loop
|call = Yearly archive list/display
|pc1n = prefix
|pc1v = {{{prefix|Archive&amp;#32;}}}
|pc2n = root
|pc2v = {{{root|}}}
|pc3n = sep
|pc3v = {{{sep|,&amp;#32;}}}
|pc4n = noredir
|pc4v = {{{noredir}}}
|pv = year
|start = 2003
|stop = {{#expr:{{CURRENTYEAR}}+1}}
|by = 1
}}
|pattern=^{{{sep|,&amp;#32;}}}
|replace=|plain=false
}}&lt;noinclude&gt;
{{doc}}
&lt;/noinclude&gt;</text>
