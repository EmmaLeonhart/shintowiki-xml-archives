      <text bytes="285" sha1="plrp7arconwaceap7ghkvkvfh81qfmk" xml:space="preserve">/* {{pp-template}} */
ruby.large {
	font-size: 250%;
}

ruby.large &gt; rt,
ruby.large &gt; rtc {
	font-size: .3em;
}

ruby &gt; rt,
ruby &gt; rtc {
	font-feature-settings: 'ruby' 1;
}

ruby.yomigana &gt; rt {
	font-feature-settings: 'ruby' 0;
}
/* [[Category:テンプレートスタイル|Ruby]] */</text>
