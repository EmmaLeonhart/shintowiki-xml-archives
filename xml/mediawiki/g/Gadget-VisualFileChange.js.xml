      <comment>maintenance: [[metawiki:User:Jon_(WMF)/Edit_to_user_or_gadget_script|more info]]     TypeError: mw.util.addPortletLink(...) is null</comment>
      <origin>778044</origin>
      <model>javascript</model>
      <format>text/javascript</format>
      <text bytes="302" sha1="3hp1fxbgf6hy22ievffaw6v48wq57ws" xml:space="preserve">$( function () {
	var link = mw.util.addPortletLink( 'p-tb', '#', window.vFC_PortletText || 'Perform batch task', 't-AjaxQuickDeleteOnDemand' );
	if(link) {
		link.addEventListener( 'click', function ( e ) {
			e.preventDefault();
			mw.loader.load( 'ext.gadget.VisualFileChange.core' );
		} );
	}
} );</text>
